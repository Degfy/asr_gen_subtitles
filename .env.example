# ASR Model Configuration
# Copy to .env and customize

# Model cache directory (default: ~/.cache/asr-models)
# ASR_MODEL_DIR=/path/to/models

# Model size key — maps to full model ID per backend (see asr/engine.py).
# Valid values: "1.7B" or "0.6B". The -8bit suffix for MLX is added automatically.
# ASR_MODEL_SIZE=1.7B

# Intermediate products directory (default: same as output_dir)
# Stores .raw.json and .lines.json for debugging and resume support
# ASR_INTERMEDIATE_DIR=/path/to/intermediate

# API Server Configuration
# API_HOST=0.0.0.0
# API_PORT=8000
